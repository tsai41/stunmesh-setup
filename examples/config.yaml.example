# Example of the stunmesh-go config generated by start.sh on EVERY start — do not edit by hand.
# Interface name is the real WireGuard interface: dynamic utunX on macOS, fixed stunmesh0 on Linux.
# Full config reference: https://github.com/tjjh89017/stunmesh-go#usage
---
refresh_interval: "1m"
log:
  level: "info"
interfaces:
  "utun4":
    protocol: "ipv4"
    peers:
      "peer":
        public_key: "<PEER_BASE64_PUBLIC_KEY>"
        plugin: dht
        protocol: "ipv4"
        ping:
          enabled: true
          target: "10.66.0.2"
          interval: "30s"
          timeout: "5s"
    listen_default_route: true
stun:
  addresses:
    - "stun.l.google.com:19302"
    - "stun1.l.google.com:19302"
plugins:
  dht:
    type: builtin
    name: opendht
    endpoint: "http://127.0.0.1:8080"
    timeout: "15s"
    # OpenDHT values expire after 10 minutes; dedup must stay false
    dedup: false

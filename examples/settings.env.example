# Example of state/settings.env, written atomically by setup.sh (and updated
# by the SSH helpers). Plain KEY=VALUE lines, parsed — never sourced/executed —
# so it is safe to hand-edit. Not secret (no private key lives here).

NODE=A
SELF_IP=10.66.0.1
PEER_IP=10.66.0.2
PEER_KEY=<PEER_BASE64_PUBLIC_KEY>
PEER_SSH_USER=karen

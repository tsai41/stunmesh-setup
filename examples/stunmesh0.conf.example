# Example of the WireGuard config generated by setup.sh (once --peer-key is provided).
# The real file contains your private key — it is gitignored, never commit it.
# Endpoint is omitted on purpose: stunmesh-go fills it in dynamically via DHT.

[Interface]
PrivateKey = <YOUR_BASE64_PRIVATE_KEY>
Address = 10.66.0.1/24

[Peer]
PublicKey = <PEER_BASE64_PUBLIC_KEY>
AllowedIPs = 10.66.0.0/24
PersistentKeepalive = 25
